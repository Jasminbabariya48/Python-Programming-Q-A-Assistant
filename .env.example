# ─── LLM Configuration (Groq — free & fast) ──────────────────────────────────
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Groq base URL (do not change)
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Model to use (free Groq models):
#   llama-3.3-70b-versatile  ← recommended (smart + fast)
#   llama-3.1-8b-instant     ← fastest / lowest latency
#   mixtral-8x7b-32768       ← long context
LLM_MODEL=llama-3.3-70b-versatile

# ─── Embedding Model (runs locally, no API key needed) ────────────────────────
EMBED_MODEL=all-MiniLM-L6-v2

# ─── Data & Index Paths ───────────────────────────────────────────────────────
DATA_DIR=data         # folder containing Questions.csv and Answers.csv
INDEX_DIR=index       # folder where FAISS index is saved / loaded

# ─── Limits ───────────────────────────────────────────────────────────────────
MAX_DOCS=50000        # max rows to index from the dataset
MAX_CONTEXT_DOCS=5    # retrieved chunks sent to the LLM
